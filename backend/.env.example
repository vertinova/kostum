# Salin ke variabel environment bila ingin mengubah default.
# (Aplikasi membaca langsung dari environment, bukan file .env.)

ADDR=:8080
BASE_URL=            # kosongkan => path foto relatif (/uploads/..), di-proxy Vite

# MySQL Laragon (default: root tanpa password)
DB_USER=root
DB_PASS=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kostum_paskibra

# Kredensial admin
ADMIN_USER=admin
ADMIN_PASS=admin123

# CORS untuk dev Vite (* = semua; produksi: set ke domain frontend)
CORS_ORIGIN=*
